/dts-v1/;

#include <dt-bindings/input/input.h>
#include <dt-bindings/leds/common.h>
#include <dt-bindings/pwm/pwm.h>
#include "rk3528.dtsi"

/ {
	model = "Radxa E24C";
	compatible = "radxa,e24c", "rockchip,rk3528a";

	aliases {
		ethernet0 = &gmac1;
		mmc0 = &sdmmc;
		mmc1 = &sdhci;
		mmc2 = &sdio0;
		rtc0 = &hym8563;
		rtc99 = &rk805;
	};

	adc-keys {
		compatible = "adc-keys";
		io-channels = <&saradc 0>;
		io-channel-names = "buttons";
		keyup-threshold-microvolt = <1800000>;
		poll-interval = <100>;

		button-maskrom {
			label = "MASKROM";
			linux,code = <KEY_SETUP>;
			press-threshold-microvolt = <0>;
		};
	};

	chosen: chosen {
		bootargs = "earlycon=uart8250,mmio32,0xff9f0000 console=ttyS0:1500000";
	};

	gpio_keys: gpio-keys {
		compatible = "gpio-keys";
		pinctrl-names = "default";
		pinctrl-0 = <&key_user>;
		autorepeat;

		button-user {
			label = "Reset Button";
			linux,code = <KEY_RESTART>;
			gpios = <&gpio0 RK_PA0 GPIO_ACTIVE_LOW>;
			debounce-interval = <100>;
		};
	};

	gpio_leds: gpio-leds {
		compatible = "gpio-leds";

		led-sys {
			color = <LED_COLOR_ID_GREEN>;
			default-state = "on";
			function = LED_FUNCTION_HEARTBEAT;
			gpios = <&gpio4 RK_PA1 GPIO_ACTIVE_LOW>;
			label = "green:sys";
			linux,default-trigger = "heartbeat";
			pinctrl-names = "default";
			pinctrl-0 = <&sys_led_g>;
		};

		led-wan {
			color = <LED_COLOR_ID_GREEN>;
			default-state = "off";	
			function = LED_FUNCTION_WAN;
			gpios = <&gpio4 RK_PA0 GPIO_ACTIVE_HIGH>;
			label = "green:wan";
			linux,default-trigger = "netdev";
			pinctrl-names = "default";
			pinctrl-0 = <&wan_led_g>;
		};

		led-lan1 {
			color = <LED_COLOR_ID_GREEN>;
			default-state = "off";	
			function = LED_FUNCTION_LAN;
			gpios = <&gpio1 RK_PB0 GPIO_ACTIVE_HIGH>;
			label = "green:lan1";
			linux,default-trigger = "netdev";
			pinctrl-names = "default";
			pinctrl-0 = <&lan1_led_g>;
		};

		led-lan2 {
			color = <LED_COLOR_ID_GREEN>;
			default-state = "off";	
			function = LED_FUNCTION_LAN;
			gpios = <&gpio1 RK_PB1 GPIO_ACTIVE_HIGH>;
			label = "green:lan2";
			linux,default-trigger = "netdev";
			pinctrl-names = "default";
			pinctrl-0 = <&lan2_led_g>;
		};

		led-lan3 {
			color = <LED_COLOR_ID_GREEN>;
			default-state = "off";	
			function = LED_FUNCTION_LAN;
			gpios = <&gpio1 RK_PB4 GPIO_ACTIVE_HIGH>;
			label = "green:lan3";
			linux,default-trigger = "netdev";
			pinctrl-names = "default";
			pinctrl-0 = <&lan3_led_g>;
		};
	};

	reserved_memory: reserved-memory {
		#address-cells = <2>;
		#size-cells = <2>;
		ranges;

		ramoops: ramoops@110000 {
			compatible = "ramoops";
			/* 0x110000 to 0x1f0000 is for ramoops */
			reg = <0x0 0x110000 0x0 0xe0000>;
			boot-log-size = <0x8000>;	/* do not change */
			boot-log-count = <0x1>;		/* do not change */
			console-size = <0x80000>;
			pmsg-size = <0x30000>;
			ftrace-size = <0x00000>;
			record-size = <0x14000>;
		};
	};

	dc12v_in: regulator-12v-dcin {
		compatible = "regulator-fixed";
		regulator-name = "dc12v-in";
		regulator-always-on;
		regulator-boot-on;
		regulator-min-microvolt = <12000000>;
		regulator-max-microvolt = <12000000>;
	};

	vcc5v0_sys: regulator-5v0-vcc-sys {
		compatible = "regulator-fixed";
		regulator-name = "vcc5v0_sys";
		regulator-always-on;
		regulator-boot-on;
		regulator-min-microvolt = <5000000>;
		regulator-max-microvolt = <5000000>;
		vin-supply = <&dc12v_in>;
	};

	vccio_sd: regulator-vccio-sd {
		compatible = "regulator-gpio";
		gpios = <&gpio4 RK_PB6 GPIO_ACTIVE_HIGH>;
		pinctrl-names = "default";
		pinctrl-0 = <&sdmmc_vol_ctrl_h>;
		regulator-min-microvolt = <1800000>;
		regulator-max-microvolt = <3300000>;
		regulator-name = "vccio_sd";
		states = <1800000 0x0>, <3300000 0x1>;
		vin-supply = <&vcc5v0_sys>;
	};

	vcc3v3_sd: regulator-3v3-vcc-sd {
		compatible = "regulator-fixed";
		regulator-name = "vcc3v3_sd";
		regulator-min-microvolt = <3300000>;
		regulator-max-microvolt = <3300000>;
		vin-supply = <&vcc_3v3>;
	};

	vcc3v3_pcie: regulator-3v3-vcc-pcie {
		compatible = "regulator-fixed";
		enable-active-high;
		gpios = <&gpio4 RK_PC6 GPIO_ACTIVE_HIGH>;
		pinctrl-names = "default";
		pinctrl-0 = <&vcc3v3_pcie_en>;
		regulator-min-microvolt = <3300000>;
		regulator-max-microvolt = <3300000>;
		regulator-name = "vcc3v3_pcie";
		startup-delay-us = <5000>;
		vin-supply = <&vcc5v0_sys>;
	};

	/*
	 * DC-DC: SY8088AAC(3v3) + SY8088AAC(1v1), max 1A
	 * input: vcc_5v0
	 * output: 3v3 to RTL8367RB AVDDH, 1v1 to RTL8367RB AVDDL
	 * enabled by GPIO1_C3
	 */
	avddl_1v1: avddh_3v3: avdd_rtl8367rb: regulator-avdd-rtl8367rb {
		compatible = "regulator-fixed";
		enable-active-high;
		gpios = <&gpio1 RK_PC3 GPIO_ACTIVE_HIGH>;
		pinctrl-names = "default";
		pinctrl-0 = <&rtl8367rb_power_en>;
		regulator-name = "avdd_rtl8367rb";
		startup-delay-us = <10000>;
		vin-supply = <&vcc5v0_sys>;
	};

	vcc5v0_usb20: regulator-5v0-vcc-usb20 {
		compatible = "regulator-fixed";
		enable-active-high;
		gpios = <&gpio1 RK_PA3 GPIO_ACTIVE_HIGH>;
		pinctrl-names = "default";
		pinctrl-0 = <&vcc5v0_usb20_en>;
		regulator-always-on;
		regulator-boot-on;
		regulator-name = "vcc5v0_usb20";
		regulator-min-microvolt = <5000000>;
		regulator-max-microvolt = <5000000>;
		vin-supply = <&vcc5v0_sys>;
	};

	pwm_fan: pwm-fan {
		compatible = "pwm-fan";
		#cooling-cells = <2>;
		cooling-min-state = <0>;
		cooling-max-state = <4>;
		cooling-levels = <0 64 128 192 255>;
		pwms = <&pwm2 0 40000 0>;
	};

	/* RTL8367RB-VB (num:6367 ver:0020) */
	switch0: switch0 {
		compatible = "realtek,rtl8367b";
		realtek,extif = <6 1 0 1 1 1 1 1 1 2>;
		mii-bus = <&mdio1>;
		phy-id = <29>;
	};
};

&combphy {
	status = "okay";
};

&cpu0 {
	cpu-supply = <&vdd_arm>;
};

&cpu1 {
	cpu-supply = <&vdd_arm>;
};

&cpu2 {
	cpu-supply = <&vdd_arm>;
};

&cpu3 {
	cpu-supply = <&vdd_arm>;
};

&gmac1 {
	/delete-property/ snps,tso;

	clock_in_out = "output";
	label = "eth0";
	phy-mode = "rgmii-rxid";
	phy-supply = <&avdd_rtl8367rb>;

	pinctrl-names = "default";
	pinctrl-0 = <&rgmii_miim>, <&rgmii_tx_bus2>, <&rgmii_rx_bus2>,
		    <&rgmii_rgmii_clk>, <&rgmii_rgmii_bus>, <&gmac1_rstn_l>;

	tx_delay = <0x3f>;
	rx_delay = <0x10>;

	snps,reset-active-low;
	/* Reset time is 25ms, 100ms for rtl8367rb */
	snps,reset-delays-us = <0 25000 100000>;
	snps,reset-gpio = <&gpio4 RK_PC2 GPIO_ACTIVE_LOW>;

	status = "okay";

	fixed-link {
		speed = <1000>;
		full-duplex;
		pause;
	};
};

/* PMIC */
&i2c0 {
	pinctrl-names = "default";
	pinctrl-0 = <&i2c0m0_xfer>;
	status = "okay";

	rk805: pmic@18 {
		compatible = "rockchip,rk805";
		reg = <0x18>;
		interrupt-parent = <&gpio4>;
		interrupts = <RK_PB2 IRQ_TYPE_LEVEL_LOW>;
		#clock-cells = <1>;
		clock-output-names = "rk805-clkout1", "rk805-clkout2";
		gpio-controller;
		#gpio-cells = <2>;
		pinctrl-names = "default";
		pinctrl-0 = <&pmic_int_l>;
		system-power-controller;
		wakeup-source;

		vcc1-supply = <&vcc5v0_sys>;
		vcc2-supply = <&vcc5v0_sys>;
		vcc3-supply = <&vcc5v0_sys>;
		vcc4-supply = <&vcc5v0_sys>;
		vcc5-supply = <&vcc5v0_sys>;
		vcc6-supply = <&vcc5v0_sys>;

		regulators {
			vdd_arm: DCDC_REG1 {
				regulator-name = "vdd_arm";
				regulator-always-on;
				regulator-boot-on;
				regulator-min-microvolt = <712500>;
				regulator-max-microvolt = <1450000>;
				regulator-ramp-delay = <12500>;

				regulator-state-mem {
					regulator-on-in-suspend;
				};
			};

			vdd_logic: DCDC_REG2 {
				regulator-name = "vdd_logic";
				regulator-always-on;
				regulator-boot-on;
				regulator-min-microvolt = <712500>;
				regulator-max-microvolt = <1450000>;
				regulator-ramp-delay = <12500>;

				regulator-state-mem {
					regulator-on-in-suspend;
				};
			};

			vcc_ddr: DCDC_REG3 {
				regulator-name = "vcc_ddr";
				regulator-always-on;
				regulator-boot-on;

				regulator-state-mem {
					regulator-on-in-suspend;
				};
			};

			vcc_3v3: DCDC_REG4 {
				regulator-name = "vcc_3v3";
				regulator-always-on;
				regulator-boot-on;
				regulator-min-microvolt = <3300000>;
				regulator-max-microvolt = <3300000>;

				regulator-state-mem {
					regulator-on-in-suspend;
					regulator-suspend-microvolt = <3300000>;
				};
			};

			vcc_1v8: LDO_REG1 {
				regulator-name = "vcc_1v8";
				regulator-always-on;
				regulator-boot-on;
				regulator-min-microvolt = <1800000>;
				regulator-max-microvolt = <1800000>;

				regulator-state-mem {
					regulator-on-in-suspend;
					regulator-suspend-microvolt = <1800000>;
				};
			};

			vcc1v8_emmc: LDO_REG2 {
				regulator-name = "vcc1v8_emmc";
				regulator-always-on;
				regulator-boot-on;
				regulator-min-microvolt = <1800000>;
				regulator-max-microvolt = <1800000>;

				regulator-state-mem {
					regulator-on-in-suspend;
					regulator-suspend-microvolt = <1800000>;
				};
			};

			vdd_0v9_p: LDO_REG3 {
				regulator-name = "vdd_0v9_p";
				regulator-always-on;
				regulator-boot-on;
				regulator-min-microvolt = <900000>;
				regulator-max-microvolt = <900000>;

				regulator-state-mem {
					regulator-on-in-suspend;
					regulator-suspend-microvolt = <900000>;
				};
			};
		};
	};
};

/* EEPROM */
&i2c1 {
	pinctrl-names = "default";
	pinctrl-0 = <&i2c1m0_xfer>;
	status = "okay";

	eeprom:	bl24c16@50 {
		compatible = "belling,bl24c16a", "atmel,24c16";
		reg = <0x50>;
		pagesize = <16>;
		read-only;
		vcc-supply = <&vcc_3v3>;
		status = "okay";
	};
};

/* LCD (option) */
&i2c2 {
	pinctrl-names = "default";
	pinctrl-0 = <&i2c2m1_xfer>;
	status = "disabled";
};

/* RTC */
&i2c5 {
	pinctrl-names = "default";
	pinctrl-0 = <&i2c5m0_xfer>;
	status = "okay";

	hym8563: hym8563@51 {
		compatible = "haoyu,hym8563";
		reg = <0x51>;
		#clock-cells = <0>;
		interrupt-parent = <&gpio4>;
		interrupts = <RK_PB0 IRQ_TYPE_LEVEL_LOW>;
		pinctrl-names = "default";
		pinctrl-0 = <&rtc_int_l>;
		wakeup-source;
	};
};

&pcie {
	reset-gpios = <&gpio1 RK_PA2 GPIO_ACTIVE_HIGH>;
	pinctrl-names = "default";
	pinctrl-0 = <&pciem1_pins>;
	vpcie3v3-supply = <&vcc3v3_pcie>;
	status = "okay";
};

&pinctrl {
	ethernet {
		gmac1_rstn_l: gmac1-rstn-l {
			rockchip,pins = <4 RK_PC2 RK_FUNC_GPIO &pcfg_pull_none>;
		};
	};

	keys {
		key_user: key-user {
			rockchip,pins = <0 RK_PA0 RK_FUNC_GPIO &pcfg_pull_up>;
		};
	};

	leds {
		lan1_led_g: lan1-led-g {
			rockchip,pins = <1 RK_PB0 RK_FUNC_GPIO &pcfg_pull_none>;
		};

		lan2_led_g: lan2-led-g {
			rockchip,pins = <1 RK_PB1 RK_FUNC_GPIO &pcfg_pull_none>;
		};

		lan3_led_g: lan3-led-g {
			rockchip,pins = <1 RK_PB4 RK_FUNC_GPIO &pcfg_pull_none>;
		};

		sys_led_g: sys-led-g {
			rockchip,pins = <4 RK_PA1 RK_FUNC_GPIO &pcfg_pull_none>;
		};

		wan_led_g: wan-led-g {
			rockchip,pins = <4 RK_PA0 RK_FUNC_GPIO &pcfg_pull_none>;
		};
	};

	pmic {
		pmic_int_l: pmic-int-l {
			rockchip,pins = <4 RK_PB2 RK_FUNC_GPIO &pcfg_pull_up>;
		};
	};

	regulators {
		vcc3v3_pcie_en: vcc3v3-pcie-en {
			rockchip,pins = <4 RK_PC6 RK_FUNC_GPIO &pcfg_pull_none>;
		};

		vcc5v0_usb20_en: vcc5v0-usb20-en {
			rockchip,pins = <1 RK_PA3 RK_FUNC_GPIO &pcfg_pull_none>;
		};

		sdmmc_vol_ctrl_h: sdmmc-vol-ctrl-h {
			rockchip,pins = <4 RK_PB6 RK_FUNC_GPIO &pcfg_pull_none>;
		};

		rtl8367rb_power_en: rtl8367rb-power-en {
			rockchip,pins = <1 RK_PC3 RK_FUNC_GPIO &pcfg_pull_none>;
		};
	};

	rtc {
		rtc_int_l: rtc-int-l {
			rockchip,pins = <4 RK_PB0 RK_FUNC_GPIO &pcfg_pull_none>;
		};
	};
};

/* PWM FAN */
&pwm2 {
	pinctrl-names = "default";
	pinctrl-0 = <&pwm2m0_pins>;
	status = "okay";
};

&saradc {
	vref-supply = <&vcc_1v8>;
	status = "okay";
};

/* In the official mass-production version, eMMC is not surface-mounted. */
&sdhci {
	bus-width = <8>;
	cap-mmc-highspeed;
	mmc-hs200-1_8v;
	no-sd;
	no-sdio;
	non-removable;
	vmmc-supply = <&vcc_3v3>;
	vqmmc-supply = <&vcc1v8_emmc>;
	status = "disabled";
};

&sdmmc {
	bus-width = <4>;
	cap-mmc-highspeed;
	cap-sd-highspeed;
	disable-wp;
	sd-uhs-sdr104;
	vmmc-supply = <&vcc3v3_sd>;
	vqmmc-supply = <&vccio_sd>;
	status = "okay";
};

&sfc {
	pinctrl-names = "default";
	pinctrl-0 = <&fspi_csn0>, <&fspi_pins>;
	status = "okay";

	flash@0 {
		compatible = "jedec,spi-nor";
		reg = <0>;
		spi-max-frequency = <50000000>;
		spi-rx-bus-width = <4>;
		spi-tx-bus-width = <1>;
		vcc-supply = <&vcc1v8_emmc>;
	};
};

&u2phy {
	status = "okay";
};

&u2phy_host {
	/* Fix ME!
	 * In the schematic, the power supply for USB host supply is actually
	 * controlled by GPIO1_A3, The correct regulator vcc5v0_usb20 has also
	 * been added to the device tree, However, if phy-supply is specified
	 * as vcc5v0_usb20, it will cause kernel panic. Therefore, it is set
	 * to vcc5v0_sys, or this attribute can be omitted.
	 */
	phy-supply = <&vcc5v0_sys>;

	status = "okay";
};

&u2phy_otg {
	vbus-supply = <&vcc_3v3>;
	status = "okay";
};

&uart0 {
	pinctrl-names = "default";
	pinctrl-0 = <&uart0m0_xfer>;
	status = "okay";
};

&usb_host0_ehci {
	status = "okay";
};

&usb_host0_ohci {
	status = "okay";
};

/*
 * Type-C is powered externally only. In the schematic,
 * the resistor from internal vcc5v0_sys to vbus_5V0 is not connected.
 * Therefore, this port can only work in OTG mode.
 */
&usb_host0_xhci {
	dr_mode = "otg";
	extcon = <&u2phy>;
	maximum-speed = "high-speed";
	phys = <&u2phy_otg>;
	phy-names = "usb2-phy";
	snps,dis_u2_susphy_quirk;
	snps,usb2-lpm-disable;
	status = "okay";
};
