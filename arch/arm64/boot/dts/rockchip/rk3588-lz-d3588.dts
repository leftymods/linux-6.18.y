&sata0 {
	status = "okay";
};

&i2c5 {
	status = "okay";
};

&uart9 {
	status = "okay";
	pinctrl-0 = <&uart9m0_xfer &uart9m0_ctsn>;
	bluetooth {
	compatible = "aicsemi,aic8800-bt";
		clocks = <&xin32k>;
		clock-names = "ext_clock";
		device-wakeup-gpios = <&gpio1 RK_PB1 GPIO_ACTIVE_HIGH>;
		interrupt-parent = <&gpio0>;
		interrupts = <RK_PA0 IRQ_TYPE_EDGE_FALLING>;
		interrupt-names = "host-wakeup";
		pinctrl-names = "default";
		pinctrl-0 = <&bt_reset_gpio>, <&bt_wake_gpio>, <&bt_irq_gpio>;
		vbat-supply = <&vcc_3v3_s3>;
		vddio-supply = <&vcc_1v8_s3>;
	};
};

&sdio {
	#address-cells = <1>;
	bus-width = <4>;
	cap-sd-highspeed;
	cap-sdio-irq;
	disable-wp;
	keep-power-in-suspend;
	max-frequency = <150000000>;
	mmc-pwrseq = <&sdio_pwrseq>;
	no-mmc;
	no-sd;
	non-removable;
	#size-cells = <0>;
	status = "okay";
	pinctrl-0 = <&sdiom0_pins>;
	brcmf: wifi@1 {
		compatible = "aicsemi,aic8800";
		reg = <1>;
		interrupt-parent = <&gpio1>;
		interrupts = <RK_PA1 IRQ_TYPE_LEVEL_HIGH>;
		interrupt-names = "host-wake";
		pinctrl-0 = <&wifi_host_wake_irq>;
		pinctrl-names = "default";
	};
};

