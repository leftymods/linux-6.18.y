	als@53 {
		compatible = "liteon,ltrf216a";
		reg = <0x53>;
		status = "okay";
	};

	eeprom@56 {
		compatible = "24c01";
		reg = <0x56>;
	};
};

/* SPI1 - Quasar/AtriStation LED screen */
&spicc1 {
	status = "okay";
	pinctrl-0 = <&spicc1_pins>;
	pinctrl-names = "default";
	num-cs = <1>;
	cs-gpios = <&gpio GPIOH_3 GPIO_ACTIVE_LOW>;

	led_screen: led-screen@0 {
		compatible = "ya,led_screen", "linux,spidev";
		reg = <0>;
		spi-max-frequency = <4000000>;
		max-brightness = <200>;
		reset-gpios = <&gpio GPIOX_10 GPIO_ACTIVE_LOW>;
		status = "okay";
	};
};

/*
 * I2C2 (Z-pins):
 *   - SY6045S tweeters (0x2a) + woofer PBTL (0x2b)
 *   - ES8156 headphone DAC (0x08)
 *   - ES7210 feedback ADC (0x40)
 *   - PCF8563 RTC (0x51)
 */
&i2c2 {
	status = "okay";
	pinctrl-0 = <&i2c2_sda_z_pins>, <&i2c2_sck_z_pins>;
	pinctrl-names = "default";
	clock-frequency = <300000>;

	rtc@51 {
		compatible = "nxp,pcf8563";
		reg = <0x51>;
		status = "okay";
	};

	eeprom@50 {
		compatible = "24c01";
		reg = <0x50>;
	};

	eeprom@52 {
		compatible = "24c01";
		reg = <0x52>;
	};

	eeprom@55 {
		compatible = "24c01";
		reg = <0x55>;
	};

	headphone_dac: es8156@8 {
		compatible = "everest,es8156";
		reg = <0x08>;
		#sound-dai-cells = <0>;
		sound-name-prefix = "Headphone";
		status = "okay";
	};

	tweeter_amp: sy6045s@2a {
		compatible = "silergy,sy6045s";
		reg = <0x2a>;
		#sound-dai-cells = <0>;
		sound-name-prefix = "Tweeters";
		vddio-supply = <&vddao_3v3>;
		pvdd-supply = <&vdd_20v_ampl>;
		restore-regs = <0x07 0x01 0xff 0x06 0x01 0x08>;
		status = "okay";
	};

	woofer_amp: sy6045s@2b {
		compatible = "silergy,sy6045s";
		reg = <0x2b>;
		#sound-dai-cells = <0>;
		sound-name-prefix = "Woofer";
		pbtl-mode;
		vddio-supply = <&vddao_3v3>;
		pvdd-supply = <&vdd_20v_ampl>;
		restore-regs = <0x07 0x01 0xff 0x06 0x01 0x08>;
		status = "okay";
	};

	mic_array: es7210@40 {
		compatible = "everest,es7210";
		reg = <0x40>;
		#sound-dai-cells = <0>;
		clocks = <&clkc_audio AUD_CLKID_MST_B_MCLK>;
		clock-names = "mclk";
		status = "okay";
	};
};

&i2c3 {
	status = "disabled";
};

&sd_emmc_a {
	status = "okay";
	pinctrl-0 = <&sdio_pins>;
	pinctrl-names = "default";
	#address-cells = <1>;
	#size-cells = <0>;
	bus-width = <4>;
	cap-sd-highspeed;
	cap-sdio-irq;
	mmc-pwrseq = <&wifi_pwrseq>;
	max-frequency = <20000000>;
	non-removable;
	disable-wp;
	keep-power-in-suspend;
	vmmc-supply = <&vddao_3v3>;
	vqmmc-supply = <&vddio_ao1v8>;

	wifi@1 {
		reg = <1>;
		compatible = "realtek,rtl8822cs";
		interrupt-parent = <&gpio>;
		interrupts = <GPIOX_9 IRQ_TYPE_LEVEL_LOW>;
	};
};

&uart_A {
	status = "okay";
	pinctrl-0 = <&uart_a_pins>, <&uart_a_cts_rts_pins>;
	pinctrl-names = "default";
	uart-has-rtscts;

	bluetooth: bluetooth {
		compatible = "realtek,rtl8822cs-bt";
		enable-gpios = <&gpio 83 /* GPIOX_19 */ GPIO_ACTIVE_HIGH>;
		host-wake-gpios = <&gpio 85 /* GPIOX_21 */ GPIO_ACTIVE_HIGH>;
		max-speed = <3000000>;
	};
};

&pwm_ef {
	status = "okay";
	pinctrl-0 = <&pwm_e_pins>;
	pinctrl-names = "default";
};

